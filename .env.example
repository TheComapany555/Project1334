# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Pre-launch site-wide password gate.
# When "true", every visitor must enter a shared access password before the
# site renders (a popup gate). The password (bcrypt-hashed) lives in the
# site_access_gate table — set/rotate it with `npm run seed:site-gate`.
# Set to "false" or remove at launch to open the site to the public.
SITE_GATE_ENABLED=false

# Stripe — products/pricing managed in admin panel, Stripe used for payments only
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@salebiz.com.au

# Where the subscribe page's "Contact sales" button sends enquiries.
# Public (exposed to the browser). Defaults to ghufran@cirqley.com if unset.
NEXT_PUBLIC_SALES_EMAIL=sales@salebiz.com.au

# ── Connected Inbox: Gmail OAuth (Spec 2b) ─────────────────────────────────
# When configured, brokers can connect their Gmail in one click. The
# Salebiz composer then sends THROUGH their Gmail account: emails appear
# in their Sent folder, replies thread to their inbox, auto-logged to CRM.
# Without these, the composer falls back to Resend outbound (works fine —
# emails just come from noreply@salebiz.com.au with the broker as Reply-To).
#
# Setup steps for the client:
#   1. Google Cloud Console → create project → enable Gmail API
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web)
#      Authorized redirect URI: <your-domain>/api/auth/google/callback
#      Authorized origin:        <your-domain>
#   3. Configure OAuth consent screen with scope:
#      https://www.googleapis.com/auth/gmail.send
#   4. Paste the two values below.
#
# GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxx
#
# Optional — defaults to ${NEXTAUTH_URL}/api/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain/api/auth/google/callback
#
# Required for storing OAuth refresh tokens at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
# EMAIL_TOKEN_ENCRYPTION_KEY=replace-with-base64-32-bytes

# ── BCC inbound email pipeline (OPTIONAL — Phase 2) ─────────────────────────
# These two vars enable the auto-BCC pipeline so brokers can BCC a private
# Salebiz address on emails they send from Gmail/Outlook and have them
# auto-logged to the CRM.
#
# M1 does NOT need them. Leave them unset and:
#   - The "Your private CRM email" card simply doesn't render
#   - /api/inbound/email returns 503 silently
#   - Brokers use the in-platform composer's "Send now" or "Log past email"
#     modes instead — both cover the spec's external-email-tracking goal
#     with zero external setup.
#
# When/if you want to enable it later, see docs/setup-bcc-email-pipeline.md
# and pick any inbound provider (Resend Inbound, SendGrid Inbound Parse,
# Cloudflare Email Workers, Mailgun Routes). Then set:
#   SALEBIZ_INBOUND_DOMAIN=mail.salebiz.com.au
#   INBOUND_EMAIL_SECRET=<openssl rand -hex 32>
# SALEBIZ_INBOUND_DOMAIN=mail.salebiz.com.au
# INBOUND_EMAIL_SECRET=replace-with-32-byte-hex

# reCAPTCHA v2
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# OpenAI (powers AI content generation in the listing form)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
# Optional. Defaults to gpt-4o-mini (good quality, low cost). Override for higher quality.
# OPENAI_MODEL=gpt-4o-mini

# Geoapify (optional — AU suburb/city autocomplete on listings, search, buyer alerts)
# Server-side key only: https://www.geoapify.com/ → create project → enable Address Autocomplete API
# GEOAPIFY_API_KEY=your-geoapify-api-key
CRON_SECRET=your-cron-secret

# ── Know Your Buyer: Sumsub identity verification ───────────────────────────
# Powers the "Know Your Buyer" tab. Brokers email buyers a Sumsub link; results
# return via /api/sumsub/webhook. Without these, the KYB form still saves but
# the "Send verification request" button returns a config error.
#
# Setup steps for the client:
#   1. Sumsub dashboard → Dev space → App tokens → generate (use the SANDBOX
#      token first). Paste the token + secret below.
#   2. Sumsub dashboard → Verification levels → copy the level name used for
#      individual ID/KYC into SUMSUB_LEVEL_NAME.
#   3. Sumsub dashboard → Dev space → Webhooks → add a webhook pointing at
#      https://<your-host>/api/sumsub/webhook and copy its secret below.
#      (Sumsub can't reach localhost — use a deployed/preview URL or a tunnel.)
# SUMSUB_APP_TOKEN=your-sumsub-app-token
# SUMSUB_SECRET_KEY=your-sumsub-secret-key
# SUMSUB_WEBHOOK_SECRET=your-sumsub-webhook-secret
# SUMSUB_LEVEL_NAME=your-individual-kyc-level
# Optional — defaults to https://api.sumsub.com (same base for sandbox & prod).
# SUMSUB_BASE_URL=https://api.sumsub.com
# Phase 2 (optional) — company/KYB verification level. When set, the KYB tab
# shows a "Company verification" action for company/trust buyers. Requires the
# company (KYB) product to be enabled on your Sumsub plan.
# SUMSUB_COMPANY_LEVEL_NAME=your-company-kyb-level

# ── Listing integrations (Agentbox / Reapit Sales connector) ────────────────
# Brings Agentbox listings into SaleBiz as drafts via a manual "Sync now" on
# /dashboard/integrations. Credentials are stored AES-256-GCM encrypted.
#
# REQUIRED to use the connector. Generate with: openssl rand -base64 32
# INTEGRATION_ENCRYPTION_KEY=replace-with-base64-32-bytes
#
# Agentbox credentials. When both are set, the agency owner's connection is
# auto-created from env (no UI paste) — matches how Stripe/Sumsub keys work.
# Leave unset to instead have each agency owner paste them in the UI.
# Client ID is a long token from Reapit — NOT the sandbox admin URL.
# AGENTBOX_CLIENT_ID=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# AGENTBOX_API_KEY=acc0-xxxx-xxxx-xxxx
#
# Optional — Agentbox-native API base URL. Defaults below. The credentials
# scope you to the sandbox vs production data set.
# AGENTBOX_API_BASE_URL=https://api.agentboxcrm.com.au
# API version query param (required by Agentbox — HTTP 300 if missing/invalid). Try 1 or 2.
# AGENTBOX_API_VERSION=1
#
# Static-IP egress proxy (PRODUCTION). Serverless hosts rotate their outbound IP,
# which Reapit can't whitelist. Point Agentbox calls at a fixed-IP proxy
# (QuotaGuard Static / Fixie) and give Reapit that proxy's IP. The provider's own
# var (QUOTAGUARDSTATIC_URL / FIXIE_URL) is also auto-detected if set.
# AGENTBOX_PROXY_URL=http://user:pass@static-proxy-host:port
#
# DEV/DEMO ONLY — when "1", the adapter returns sample fixtures instead of
# calling the (IP-restricted) live API. OMIT in production to use real data.
# AGENTBOX_USE_FIXTURES=1